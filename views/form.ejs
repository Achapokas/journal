<form method="POST" action="/journals/new">
<label for="title">Name:</label>
<input type="text" id="title" name="title" placeholder="New journal">

<!-- Multi-line for the message -->
<label for="body">Message:</label>
<textarea id="body" name="body" rows="5" placeholder="Type your message here..."></textarea>

<!-- Submission button -->
<button type="submit">Send Message</button>
</form>